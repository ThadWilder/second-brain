# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# Managed Agents (Anthropic)
MANAGED_AGENT_ID=your-managed-agent-id
MANAGED_ENVIRONMENT_ID=your-managed-environment-id

# Postmark
POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_WEBHOOK_SECRET=your-postmark-webhook-secret
POSTMARK_FROM_EMAIL=brain@yourdomain.com
POSTMARK_TO_EMAIL=brandy@yourdomain.com

# Cron secret — include in Authorization header for cron route calls
CRON_SECRET=your-cron-secret

# Org ID — hardcoded for v1 single-user
ORG_ID=00000000-0000-0000-0000-000000000001

# Auth allowlist — comma-separated lowercase emails permitted to sign in via Google OAuth.
# Anyone not in this list is bounced back to /login. No spaces required.
ALLOWED_EMAILS=you@example.com,teammate@example.com

# App URL (for cron callbacks, reply-to links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
